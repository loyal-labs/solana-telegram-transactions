{
  "name": "@loyal-labs/loyal-smart-accounts-core",
  "version": "0.1.0",
  "description": "Core artifacts and low-level builders for the Loyal smart accounts SDK",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./loyal": {
      "import": "./dist/loyal.js",
      "types": "./dist/loyal.d.ts"
    },
    "./internal": {
      "import": "./dist/internal.js",
      "types": "./dist/internal.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "upstream"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "bun run clean && bun run build:js && bun run build:types",
    "build:js": "bun build ./index.ts ./internal.ts ./loyal.ts --outdir ./dist --target browser --format esm --external @loyal-labs/solana-rpc --external @solana/web3.js --external @solana/spl-token",
    "build:types": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build",
    "clean": "rm -rf dist",
    "test": "bun test"
  },
  "author": "Loyal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/loyal/loyal-app.git",
    "directory": "sdk/loyal-smart-accounts-core"
  },
  "peerDependencies": {
    "@solana/web3.js": "^1.98.0"
  },
  "dependencies": {
    "@loyal-labs/solana-rpc": "workspace:*",
    "@metaplex-foundation/beet": "0.7.1",
    "@metaplex-foundation/beet-solana": "0.4.0",
    "@metaplex-foundation/cusper": "^0.0.2",
    "@solana/spl-token": "^0.4.13",
    "assert": "^2.1.0",
    "bn.js": "^5.2.2",
    "buffer": "^6.0.3",
    "invariant": "^2.2.4"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.6",
    "@types/bun": "latest",
    "@types/invariant": "^2.2.37",
    "@types/node": "^24.0.15",
    "typescript": "^5.7.3"
  },
  "peerDependenciesMeta": {
    "@solana/web3.js": {
      "optional": false
    }
  }
}
